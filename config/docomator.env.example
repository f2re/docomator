# Core
DOCOMATOR_VERSION=0.1.0-alpha.0
DOCOMATOR_HOST=127.0.0.1
DOCOMATOR_PORT=8080
DOCOMATOR_DATA_DIR=/var/lib/docomator
DOCOMATOR_LOG_LEVEL=info
DOCOMATOR_SESSION_SECRET=CHANGE_ME_DURING_INSTALL

# Worker. Leave WORKER_ID empty to derive hostname:pid.
DOCOMATOR_WORKER_ID=
DOCOMATOR_WORKER_POLL_MS=1000
DOCOMATOR_WORKER_HEARTBEAT_MS=30000
DOCOMATOR_WORKER_LEASE_MS=60000
DOCOMATOR_WORKER_RETRY_BASE_MS=1000
DOCOMATOR_WORKER_RETRY_MAX_MS=300000

# Automatic backup. The systemd timer runs daily around 03:15 local time.
# Copies are stored in <DOCOMATOR_DATA_DIR>/backups.
DOCOMATOR_BACKUP_ENABLED=true
DOCOMATOR_BACKUP_RETENTION=7

# Local LLM
DOCOMATOR_LLM_ENABLED=false
DOCOMATOR_LLM_BASE_URL=http://127.0.0.1:8081
DOCOMATOR_LLM_MODEL=/var/lib/docomator/models/model.gguf
DOCOMATOR_LLM_HOST=127.0.0.1
DOCOMATOR_LLM_PORT=8081
DOCOMATOR_LLM_CONTEXT=4096
DOCOMATOR_LLM_THREADS=8

# Preview
DOCOMATOR_PREVIEW_ENABLED=true
DOCOMATOR_LIBREOFFICE_BIN=/usr/bin/libreoffice

# Delivery. Leave the network root empty to disable network-folder delivery.
# The directory must already be mounted on the host and writable by the docomator service user.
DOCOMATOR_NETWORK_DELIVERY_ROOT=

# SMTP. Secrets must be configured only on the target host.
# SMTP remains disabled until sender and allowed recipient domains are set.
DOCOMATOR_SMTP_ENABLED=false
DOCOMATOR_SMTP_HOST=127.0.0.1
DOCOMATOR_SMTP_PORT=25
# true = implicit TLS, normally port 465.
DOCOMATOR_SMTP_SECURE=false
# true = require STARTTLS on a plain connection. Must be false when SECURE=true.
DOCOMATOR_SMTP_STARTTLS=true
DOCOMATOR_SMTP_REJECT_UNAUTHORIZED=true
DOCOMATOR_SMTP_FROM=
DOCOMATOR_SMTP_FROM_NAME=Docomator
# Comma-separated exact domains, wildcard subdomains (*.example.org), or *.
DOCOMATOR_SMTP_ALLOWED_DOMAINS=
DOCOMATOR_SMTP_MAX_ATTACHMENT_BYTES=20971520
DOCOMATOR_SMTP_TIMEOUT_MS=30000
DOCOMATOR_SMTP_USER=
DOCOMATOR_SMTP_PASSWORD=
